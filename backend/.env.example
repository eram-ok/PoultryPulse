APP_NAME=PoultryPulse
APP_VERSION=0.1.0
APP_ENVIRONMENT=development
APP_DEBUG=true

API_V1_PREFIX=/api/v1

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=poultrypulse
DATABASE_USER=your_database_user
DATABASE_PASSWORD=your_secure_database_password
DATABASE_URL=postgresql+psycopg://your_database_user:your_secure_database_password@localhost:5432/poultrypulse

JWT_SECRET_KEY=generate_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Stage 16 notification delivery
ALERT_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=PoultryPulse
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=20

ALERT_SMS_ENABLED=false
SMS_PROVIDER=africastalking

AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=
AFRICASTALKING_API_URL=https://api.africastalking.com/version1/messaging

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

GENERIC_SMS_URL=
GENERIC_SMS_API_KEY=
GENERIC_SMS_AUTH_HEADER=Authorization
GENERIC_SMS_AUTH_PREFIX=Bearer 
GENERIC_SMS_TO_FIELD=to
GENERIC_SMS_MESSAGE_FIELD=message
GENERIC_SMS_SENDER_FIELD=sender
GENERIC_SMS_SENDER_ID=PoultryPulse

ALERT_MAX_DELIVERY_ATTEMPTS=3
ALERT_RETRY_DELAY_MINUTES=15

# Stage 18A application security hardening
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
ALLOWED_HOSTS=localhost,127.0.0.1,testserver
CORS_ALLOWED_ORIGINS=
CORS_ALLOW_CREDENTIALS=true
TRUSTED_PROXY_IPS=
MAX_REQUEST_BODY_BYTES=1048576
SECURITY_HEADERS_ENABLED=true
HSTS_ENABLED=false
HSTS_MAX_AGE_SECONDS=31536000
AUTH_RATE_LIMIT_ENABLED=false
AUTH_RATE_LIMIT_REQUESTS=120
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
DOCS_ENABLED=true
JWT_ISSUER=PoultryPulse
JWT_AUDIENCE=poultrypulse-api
JWT_VALIDATE_ISSUER_AUDIENCE=false
JWT_LEEWAY_SECONDS=30

# Stage 18B — operational resilience
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_POOL_RECYCLE_SECONDS=1800
DATABASE_CONNECT_TIMEOUT_SECONDS=10
READINESS_DATABASE_TIMEOUT_SECONDS=3
STARTUP_DATABASE_CHECK_ENABLED=false
STARTUP_DATABASE_CHECK_REQUIRED=false
LOG_LEVEL=INFO
LOG_FORMAT=text
REQUEST_LOGGING_ENABLED=true
REQUEST_LOGGING_EXCLUDED_PATHS=/api/v1/health/live,/api/v1/health/ready
UVICORN_ACCESS_LOG_ENABLED=false
